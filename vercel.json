{
  "installCommand": "cd frontend && npm install",
  "buildCommand": "cd frontend && npx expo export --platform web",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/((?!_expo|assets|favicon\\.ico).*)",
      "destination": "/index.html"
    }
  ]
}
